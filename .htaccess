<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(composer\.(json|lock)|package\.json|\.env|\.gitignore|\.htaccess)$">
    Require all denied
</FilesMatch>